--8. COLLECTION WORKFLOW (REAL BUSINESS SIMULATION)
-- ============================================
-- PURPOSE:
-- Simulate real-world collection action strategy
-- ============================================

select
    account_id,
    customer_name,
    delinquency_days,
    debt_amount,

    case 
        when delinquency_days > 90 then 'Immediate Call + Escalation'
        when delinquency_days > 60 then 'High Priority Call'
